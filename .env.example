# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Registration Access Token (WAJIB diisi - untuk proteksi halaman registrasi).
# Buat token rahasia (panjang min. 16 char) dan buka halaman dengan:
#   /register?token=VALUE
# Catatan: tidak ada fallback. Jika kosong, /register akan selalu 403.
REGISTER_ACCESS_TOKEN=

# Optional: App URL untuk email redirect (forgot password / verify email)
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=
